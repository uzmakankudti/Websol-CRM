# =====================================================================
# Websol CRM — Shared environment variables (TEMPLATE)
# =====================================================================
# Copy this file to `.env` (root) for tooling, AND copy the values into
# backend/local.settings.json for Azure Functions local runs.
# NEVER commit real secrets. In Azure, set these in App Settings / Key Vault.
# =====================================================================

# --- MySQL database connection ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=websol
DB_PASSWORD=change_me
DB_NAME=websol_crm
# Max connections in the pool. Keep SMALL for serverless to avoid
# exhausting the database (many function instances x pool size).
DB_CONNECTION_LIMIT=5
# Set to "true" when connecting to Azure Database for MySQL (requires SSL).
DB_SSL=false

# --- App / secrets ---
NODE_ENV=development
# A secret used for signing tokens, sessions, etc.
APP_SECRET=replace_with_a_long_random_string
